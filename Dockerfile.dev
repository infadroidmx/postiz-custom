# Stage 1: Build dependencies and compile
FROM node:22.20-bookworm-slim AS builder

ARG NEXT_PUBLIC_VERSION
ENV NEXT_PUBLIC_VERSION=$NEXT_PUBLIC_VERSION

RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    python3 \
    bash \
    && rm -rf /var/lib/apt/lists/*

RUN npm --no-update-notifier --no-fund --global install pnpm@10.6.1

WORKDIR /app

# Copy context and install
COPY . .
RUN pnpm install --no-frozen-lockfile --ignore-scripts

# Generate Prisma and build
RUN pnpm run prisma-generate
RUN NODE_OPTIONS="--max-old-space-size=4096" pnpm run build

# Remove development dependencies
RUN pnpm prune --prod --ignore-scripts

# Stage 2: Final runtime image
FROM node:22.20-bookworm-slim AS runner

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx \
    bash \
    && rm -rf /var/lib/apt/lists/*

RUN npm --no-update-notifier --no-fund --global install pnpm@10.6.1 pm2

# Setup runner environment
RUN mkdir -p /app
WORKDIR /app

# Copy full context from builder to preserve symlinks and relative paths
COPY --from=builder /app /app
COPY --from=builder /app/var/docker/nginx.conf /etc/nginx/nginx.conf

# Ensure a .env file exists for the backend start scripts
RUN touch .env

EXPOSE 5000

CMD ["sh", "-c", "nginx && pnpm run pm2"]
